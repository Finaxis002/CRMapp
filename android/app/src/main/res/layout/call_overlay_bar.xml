<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1D23"
    android:padding="12dp">

    <!-- Collapsed row: status + Note/Task buttons -->
    <LinearLayout
        android:id="@+id/collapsedRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Call in progress"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnNote"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:text="+ Note"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5A7BF6" />

        <Button
            android:id="@+id/btnTask"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Task"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#16A34A" />
    </LinearLayout>

    <!-- Expanded form: hidden by default -->
    <LinearLayout
        android:id="@+id/expandedForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="10dp">

        <EditText
            android:id="@+id/inputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:maxLines="4"
            android:gravity="top"
            android:background="#23262E"
            android:textColor="#FFFFFF"
            android:textColorHint="#9CA3AF"
            android:padding="8dp"
            android:hint="Enter your text..." />

        <!-- Task date picker: hidden by default -->
        <Button
            android:id="@+id/btnPickDate"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Select Due Date: Today"
            android:textSize="12sp"
            android:backgroundTint="#374151"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Cancel"
                android:textSize="12sp"
                android:backgroundTint="#374151"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="38dp"    
                android:layout_weight="1"
                android:text="Save"
                android:textSize="12sp"
                android:backgroundTint="#5A7BF6"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>