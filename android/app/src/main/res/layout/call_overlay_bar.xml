<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1D23"
    android:padding="14dp">

    <!-- Row 1: status text + close button -->
    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Call in progress"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="Close overlay"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#9CA3AF" />
    </LinearLayout>

    <!-- Row 2: action buttons -->
    <LinearLayout
        android:id="@+id/buttonsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnNote"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="+ Note"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5A7BF6" />

        <Button
            android:id="@+id/btnTask"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="+ Task"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#16A34A" />

        <Button
            android:id="@+id/btnNewLead"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="+ Lead"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9333EA" />
    </LinearLayout>

    <!-- Collapsed row: status + Note/Task/New Lead buttons + manual close -->
    <LinearLayout
        android:id="@+id/collapsedRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
    </LinearLayout>

    <!-- Expanded form: hidden by default -->
    <LinearLayout
        android:id="@+id/expandedForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="10dp">

        <EditText
            android:id="@+id/inputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:maxLines="5"
            android:gravity="top"
            android:background="#23262E"
            android:textColor="#FFFFFF"
            android:textColorHint="#9CA3AF"
            android:padding="8dp"
            android:hint="Enter your text..." />

        <!-- Task date picker: hidden by default -->
        <Button
            android:id="@+id/btnPickDate"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Select Due Date: Today"
            android:textSize="12sp"
            android:backgroundTint="#374151"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Cancel"
                android:textSize="12sp"
                android:backgroundTint="#374151"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="Save"
                android:textSize="12sp"
                android:backgroundTint="#5A7BF6"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
